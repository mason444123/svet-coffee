# Copy this file to .env. Never publish .env or put it inside a website archive.
SVET_HOST=127.0.0.1
SVET_PORT=8080

# Generate a NEW token in @BotFather after revoking the token shared in chat.
TELEGRAM_BOT_TOKEN=

# Optional fixed Telegram user IDs. Comma-separated, without @username.
TELEGRAM_ADMIN_IDS=

# Generate with: python scripts/generate_bot_pin.py
TELEGRAM_ACCESS_PIN_HASH=

# Public production origins, comma-separated. Local same-origin requests work automatically.
SVET_ALLOWED_ORIGINS=https://example.ru
SVET_LOG_LEVEL=INFO
